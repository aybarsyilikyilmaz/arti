# Bu dosyayı .env olarak kopyalayıp değerleri doldurun. .env asla commit edilmez.
NODE_ENV=development
# macOS'ta 5000 portunu AirPlay Receiver kullanır
PORT=5002

# MongoDB Atlas bağlantı dizesi (lokalde: mongodb://localhost:27017/arti)
MONGO_URI=mongodb://localhost:27017/arti

# En az 32 karakter. Üretim: openssl rand -hex 48
JWT_SECRET=degistir-bunu-en-az-32-karakterlik-rastgele-bir-deger-yap

# KVKK alan şifrelemesi — tam 64 hex karakter. Üretim: openssl rand -hex 32
ENCRYPTION_KEY=degistir-64-hex-karakter

# Webhook HMAC imzalari. Üretim: openssl rand -hex 32
WEBHOOK_SECRET=degistir-rastgele-deger

# Opsiyonel
# ACCESS_TOKEN_TTL=15m
# REFRESH_TTL_DAYS=30
# PAYMENT_PROVIDER=mock
# RESERVATION_TTL_MIN=10
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# LOG_LEVEL=debug

# Faz 2
REDIS_URL=redis://localhost:6379
# Desk360 webhook URL yolu icin token. Uretim: openssl rand -hex 24
DESK360_WEBHOOK_TOKEN=degistir-rastgele-token
# DESK360_API_URL=
# DESK360_API_KEY=
# OUTREACH_LEAD_MIN=240
# FALLBACK_LEAD_MIN=60

# Faz 3 — depolama & deploy
# local: dosyalar backend/uploads altına yazılır (dev)
# s3: AWS S3 presigned upload (S3_BUCKET + S3_REGION zorunlu; kimlik EC2 IAM role'den)
STORAGE_PROVIDER=local
# S3_BUCKET=arti-uploads-prod
# S3_REGION=eu-central-1
# S3_PUBLIC_BASE=https://cdn.artiapp.com.tr        # CloudFront/CDN varsa
# PUBLIC_API_URL=https://api.artiapp.com.tr        # lokal modda presigned URL tabanı
# HOST=127.0.0.1                                   # üretimde Nginx arkasında loopback
